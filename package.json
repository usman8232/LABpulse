{
  "name": "labpulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "agent"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "dev:agent": "npm run dev --workspace agent",
    "local": "npm run setup:env && node scripts/run-local.mjs",
    "local:with-agent": "npm run setup:env && node scripts/run-local.mjs --with-agent",
    "start:server": "npm run start --workspace server",
    "start:agent": "npm run start --workspace agent",
    "setup:env": "node scripts/setup-env.mjs",
    "up": "npm run setup:env && docker compose up --build",
    "up:detached": "npm run setup:env && docker compose up --build -d",
    "down": "docker compose down",
    "logs": "docker compose logs -f",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --write"
    ]
  }
}
